# Velith environment configuration (M0).
# Copy this file to `.env` and adjust as needed. `.env` is gitignored and is
# NEVER committed. These are placeholders only — no real secrets belong here.
#
# All variables are optional in M0: every setting has a safe default, so the
# system loads and validates with no .env present. An *invalid* value (e.g. an
# unknown log level) makes configuration fail loudly at startup (M0 §10).

# Deployment context. One of: development | ci | production
VELITH_ENVIRONMENT=development

# Logging verbosity. One of: DEBUG | INFO | WARNING | ERROR | CRITICAL
VELITH_LOG_LEVEL=INFO

# Logging output format. One of: json | console
VELITH_LOG_FORMAT=json

# Path to the derived SQLite index over the episode log (M3). The JSONL log is
# authoritative; this index is a rebuildable projection of it. It lives under the
# gitignored `data/episodes/` directory and has a safe default, so it need not be
# set. Override only to relocate the index file.
VELITH_EPISODE_INDEX_PATH=data/episodes/episodes.db
