# Velith environment configuration (M0).
# Copy this file to `.env` and adjust as needed. `.env` is gitignored and is
# NEVER committed. These are placeholders only — no real secrets belong here.
#
# All variables are optional in M0: every setting has a safe default, so the
# system loads and validates with no .env present. An *invalid* value (e.g. an
# unknown log level) makes configuration fail loudly at startup (M0 §10).

# Deployment context. One of: development | ci | production
VELITH_ENVIRONMENT=development

# Logging verbosity. One of: DEBUG | INFO | WARNING | ERROR | CRITICAL
VELITH_LOG_LEVEL=INFO

# Logging output format. One of: json | console
VELITH_LOG_FORMAT=json

# Path to the derived SQLite index over the episode log (M3). The JSONL log is
# authoritative; this index is a rebuildable projection of it. It lives under the
# gitignored `data/episodes/` directory and has a safe default, so it need not be
# set. Override only to relocate the index file.
VELITH_EPISODE_INDEX_PATH=data/episodes/episodes.db

# --- M4: task corpus + held-out lock (path-only; consumed from M4-C2 onward) ---
# These only locate the inputs; no partition logic lives in configuration. All have
# safe defaults, so they need not be set.
# Root of the task corpus source (opaque task materials).
VELITH_CORPUS_PATH=data/corpus
# Content-addressed partition manifest (available/held-out assignment + hash).
VELITH_CORPUS_MANIFEST_PATH=data/corpus/manifest.json
# Declared partition specification (the pre-committed available/held-out split).
VELITH_CORPUS_PARTITION_SPEC_PATH=data/corpus/partition.json

# --- M5: batch runner + cold baseline arm A0 (consumed from M5-C2 onward) ---
# All have safe defaults; `0` limits mean "unbounded". These are recorded in the run
# provenance as the sweep's experiment identity.
# The fixed base model for a batch sweep (one non-saturating model).
VELITH_BATCH_BASE_MODEL=qwen2.5-coder
# The run's batch seed; each task's seed is derived from (task identity, batch seed).
VELITH_BATCH_SEED=0
# Cost-guard limits: max tasks attempted, attempts/retries per task, token budget.
VELITH_BATCH_MAX_TASKS=0
VELITH_BATCH_MAX_ATTEMPTS_PER_TASK=1
VELITH_BATCH_MAX_TOKENS=0

# --- M6: shared retrieval substrate (read-only; consumed from M6-C3 onward) ---
# All have safe defaults. Retrieval is read-only and deterministic.
# Number of neighbours the retriever returns.
VELITH_RETRIEVAL_TOP_K=5
# The single fixed, deterministic, domain-neutral embedding component (no routing).
VELITH_RETRIEVAL_EMBEDDER=hashed-ngram
# The read-only episode memory the retriever reads (defaults to the M3 episode log).
VELITH_RETRIEVAL_MEMORY_PATH=data/episodes/episodes.jsonl
